# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Test, lint, type-check, and coverage outputs
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Local Python and conda environments
.venv/
venv/
env/
ENV/
.conda/
conda-env/

# Article source and the compiled release PDF are tracked; ignore LaTeX build artifacts.
article/*.aux
article/*.bbl
article/*.blg
article/*.fdb_latexmk
article/*.fls
article/*.log
article/*.synctex.gz
article/_pdf_pages/

# Local generated deliverables (do not publish).
output/

# Environment variable files
.env
.env.*
!.env.example

# Marine race and simulator generated outputs.
# Ignore each entry under results/ (so results/rl/ etc. stay ignored) but allow git
# to descend so results/rl_public/ can be re-included (see end of file).
/results/*
!/results/rl_public/
logs/
runs/
/diagnostics/
recordings/
videos/
HoloOceanLogs/
Saved/
*.jsonl
*_summary.json
*.log
*.out
*.err

# Video and large generated artifacts
*.mp4
*.avi
*.mov
*.mkv
*.bag
*.ulg
*.npy
*.npz

# Temporary and backup files
*.tmp
*.bak
*.swp
*.swo
*~

# OS and editor files
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# Local agent/tool state
.agents/
.codex/

# --- Public, auditable RL result package -------------------------------------
# results/rl/ (heavy datasets/models/checkpoints/logs) stays ignored above.
# results/rl_public/ holds only compact, audit-relevant artifacts and IS tracked.
# These re-include rules are last so they override results/ and the *_summary.json
# / *.jsonl / *.npz patterns for this subtree only.
!results/rl_public/
!results/rl_public/**
# ...but never commit heavy binaries even under rl_public (models/checkpoints/data):
results/rl_public/**/*.zip
results/rl_public/**/*.npz
results/rl_public/**/*.npy
results/rl_public/**/*.mp4
